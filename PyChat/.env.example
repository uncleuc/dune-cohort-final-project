# Copy this file to .env and replace placeholder values before running the app.

SECRET_KEY=replace-with-a-secure-django-secret-key
DEBUG=True
DATABASE_URL=sqlite:///db.sqlite3
RENDER_EXTERNAL_HOSTNAME=
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
REDIS_URL=

# SECRET_KEY: Django secret used for signing sessions and CSRF tokens.
# DEBUG: Enables Django debug mode locally; set to False in production.
# DATABASE_URL: SQLite for local development or PostgreSQL for Render.
# RENDER_EXTERNAL_HOSTNAME: Used by Render to allow the deployed host.
# CSRF_TRUSTED_ORIGINS: Additional origins allowed for Django CSRF validation.
# REDIS_URL: Optional future setting for Redis-backed Channels in production.
