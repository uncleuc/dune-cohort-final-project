  "item": [
    {
      "name": "Token Auth",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Token received and saved\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.token).to.be.a(\"string\");",
              "    pm.environment.set(\"access_token\", jsonData.token);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "type": "text",
              "key": "username",
              "value": "kelvin"
            },
            {
              "type": "text",
              "key": "password",
              "value": "admin"
            }
          ]
        },
        "url": {
          "raw": "https://ai.softshell-diminished.ts.net/api/token-auth/",
          "protocol": "https",
          "host": [
            "ai",
            "softshell-diminished",
            "ts",
            "net"
          ],
          "path": [
            "api",
            "token-auth",
            ""
          ]
        },
        "description": "Generated from cURL: curl -X POST https://ai.softshell-diminished.ts.net/api/token-auth/ --data-urlencode \"username=kelvin\" --data-urlencode \"password=admin\""
      },
      "response": []
    },
